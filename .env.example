# === LLM Provider ===
# Pelo menos uma chave é necessária para respostas de IA livre.
# Sem nenhuma chave, o assistente responde apenas com a base de conhecimento (KB).
# Cenários que exigem LLM falharão com erro explícito (503).
GROQ_API_KEY=

# Fallback: usado apenas se GROQ_API_KEY estiver vazio
# OPENROUTER_API_KEY=

# === Debug ===
# Exibe campo de texto e transcrição no assistente
# NEXT_PUBLIC_ASSISTENTE_TEXT_DEBUG=true
